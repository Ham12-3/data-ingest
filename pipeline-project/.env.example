# =============================================================================
# Data Ingestion Pipeline — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your deployment.
# Docker Compose service names are used as default hostnames.
# =============================================================================

# ──────────────────────────────────────────────
# Kafka Configuration
# ──────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka-1:9092,kafka-2:9093,kafka-3:9094
KAFKA_SCHEMA_REGISTRY_URL=http://schema-registry:8081

# ──────────────────────────────────────────────
# Producer Settings
# ──────────────────────────────────────────────
PRODUCER_EVENTS_PER_SECOND=100
PRODUCER_BATCH_SIZE=500

# ──────────────────────────────────────────────
# Flink Consumer Settings
# ──────────────────────────────────────────────
FLINK_CHECKPOINT_INTERVAL=60000
FLINK_PARALLELISM=2
FLINK_STATE_BACKEND=rocksdb

# ──────────────────────────────────────────────
# PostgreSQL Configuration
# ──────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pipeline_db
POSTGRES_USER=pipeline_user
POSTGRES_PASSWORD=pipeline_pass
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# ──────────────────────────────────────────────
# Redis Configuration
# ──────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=20

# ──────────────────────────────────────────────
# API Settings
# ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_LOG_LEVEL=info
API_CORS_ORIGINS=["http://localhost:3000"]

# ──────────────────────────────────────────────
# Monitoring & Observability
# ──────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=admin
LOG_LEVEL=INFO
LOG_FORMAT=json

# ──────────────────────────────────────────────
# Data Quality Settings
# ──────────────────────────────────────────────
QUALITY_CHECK_ENABLED=true
QUALITY_SAMPLE_RATE=0.1
QUALITY_FAIL_ON_ERROR=false
QUALITY_EXPECTATION_SUITE=default
